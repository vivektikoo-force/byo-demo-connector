################################################
##                                            ##
##     env vars for remote-control (Voice)    ##
##                                            ##
################################################
#Server app will listen on this port. Only change if you want to use other port.
SERVER_PORT=3030
#Server Url. Only change if you want to use other port.
SERVER_URL=http://localhost:3030
#Contact Center Phone No. Only Change if you want to use any other Contact Center Number
CALL_CENTER_NO=4150000000
#Only use if you want to bypass SCRT and use your own VoiceCallId for inbound call
#OVERRIDE_VOICECALLID=0LQxx0000004C92GAE

################################################
##                                            ##
##       env vars for ottApp (Messaging)      ##
##                                            ##
################################################

#########################################
## Section #1:                         ##
##  The entries that are not           ##
##  dynamically fetched from core,they ##
##  are manually set here.             ##
#########################################
SF_CONSUMER_KEY="<connected app consumer key>"
SF_PRIVATE_KEY="<private key>"
SF_AUDIENCE=https://login.salesforce.com
SF_SUBJECT=<admin user name>
SF_AUTH_ENDPOINT=https://login.salesforce.com/services/oauth2/token
SF_PUB_SUB_ENDPOINT=api.pubsub.salesforce.com:7443
SF_PUB_SUB_EVENT_RECEIVE_LIMIT=100
SF_INSTANCE_URL=<Salesforce core app instance url>
SF_SCRT_INSTANCE_URL=<Salesforce core app scrt2 instance url>
SF_ORG_ID=<orgId>
SF_PASSWORD=<Admin user password>
SF_AUTHORIZATION_CONTEXT=<ConversationChannelDefinition API Name>
CHANNEL_ADDRESS_IDENTIFIER=<Channel address identifier>
END_USER_CLIENT_IDENTIFIER=<End user client identifier>
API_VERSION=<Ex: "63.0" API version for the current release of salesforce app>

#########################################
## Section #2:                         ##
##  The entries that are for BYO CCaaS ##
#########################################
USER_ID=<Valid salesforce or external user id>
ROUTING_OWNER=<Owner of Routing possible values Partner|Salesforce>[^9]
CAPACITY_WEIGHT=<Capacity weight which will be used in agent work example value:1>
AUTO_CREATE_AGENT_WORK=true

############################################
## Section #3: Indicator to specify       ##
## whether to dynamically fetch following ##
## entries from core:                     ##
##   - SF_INSTANCE_URL                    ##
##   - SF_SCRT_INSTANCE_URL               ##
##   - SF_AUTHORIZATION_CONTEXT           ##
##   - SF_ORG_ID                          ##
##   - USER_ID                            ##
##   - SF_SUBJECT                         ##
############################################
IS_LOCAL_CONFIG=<true: read from local env config, or false: read from core>

############################################
## Note: The following values will be     ##
## loaded from CCD for non-voiceOnly case ##
##   - Custom event topic name            ##
##   - Custom event payload field name    ##
##   - Custom event type field name       ##
##   - Consent Owner                      ##
##   - Routing Owner                      ##
############################################
